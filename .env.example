# Freezer App — Environment Configuration
# Copy this file to .env and set your own values.
# .env is git-ignored and will never be committed.

# Server
PORT=3000
# DB_PATH=data/freezer.db

# Logging
# LOG_LEVEL: debug | info | warn | error  (default: info)
# LOG_FILE: path to log file (default: data/server.log in working directory)
LOG_LEVEL=info
# LOG_FILE=data/server.log

# Email Alerts (via Gmail SMTP)
# To get an app password: https://myaccount.google.com/apppasswords
# If any value is left empty, alerts are silently disabled.
# ALERT_SMTP_HOST=smtp.gmail.com
# ALERT_SMTP_PORT=587
# ALERT_EMAIL=your-email@gmail.com
# ALERT_APP_PASSWORD=your-16-char-app-password
# ALERT_TO=your-email@gmail.com

# Auth
# Users are stored in the database. No environment variable needed.
# To add users on the Pi:
#   1. Generate password hashes:
#        ./freezer-server --hash-password
#      (enter password, copy the hash)
#   2. Insert into database:
#        sqlite3 data/freezer.db "INSERT INTO users (email, password_hash) VALUES ('you@email.com', 'PASTE_HASH_HERE');"
#        sqlite3 data/freezer.db "INSERT INTO users (email, password_hash) VALUES ('wife@email.com', 'PASTE_HASH_HERE');"
#   3. Restart: sudo systemctl restart freezer-app
